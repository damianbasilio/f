# Google Stitch API — stitch.withgoogle.com → Profile → Stitch settings
STITCH_API_KEY=

# Multiple keys (parallel builds + credit failover):
# STITCH_API_KEYS=key1,key2,key3,key4,key5,key6
# STITCH_CONCURRENCY=6
# STITCH_BUILD_DELAY_MS=0

# Gmail outreach send (Google Account → Security → 2FA → App passwords)
GMAIL_USER=
GMAIL_APP_PASSWORD=
# OUTREACH_SEND_DELAY_MS=45000

# Groq — AI outreach email drafts (console.groq.com → API Keys)
# Default: llama-3.1-8b-instant (500K tokens/day, 6K TPM)
# Best prose: llama-3.3-70b-versatile (100K tokens/day only — ~27 emails)
GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MODEL=qwen/qwen3-32b
# GROQ_TPM=6000
# GROQ_EST_TOKENS=1900
# GROQ_COOLDOWN_MS=25000
# GROQ_MAX_RETRIES=3

# GitHub Pages auto-deploy after each mockup finishes (commit + push main)
# GITHUB_DEPLOY=1
# GITHUB_REPO=https://github.com/damianbasilio/f.git
# GITHUB_TOKEN=ghp_...          # only if git push needs a token (HTTPS remote)
# GIT_REMOTE=origin
# GIT_BRANCH=main
# GIT_USER_NAME=damianbasilio
# GIT_USER_EMAIL=damian.basilio@icloud.com
# Must match your GitHub account exactly. Do not use "dambasilio" or dam.basilio@gmail.com for commits.
# GITHUB_PAGES_WAIT_MS=180000
# GITHUB_PAGES_POLL_MS=10000
# POST_BUILD_MAX_RETRIES=3
