# Dashboard web UI (npm run server / PM2 outreach-dashboard)
# Generate: openssl rand -base64 24
DASHBOARD_PASSWORD=
# Optional — keeps sessions valid across restarts (openssl rand -hex 32)
# DASHBOARD_SESSION_SECRET=

# Google Stitch API — stitch.withgoogle.com → Profile → Stitch settings
STITCH_API_KEY=

# Multiple keys (round-robin per slug + credit failover to next key):
# STITCH_API_KEYS=key1,key2,key3,key4,key5,key6
# STITCH_CONCURRENCY=6
# STITCH_BUILD_DELAY_MS=0
# PIPELINE_CONCURRENCY=3

# Gmail outreach send (Google Account → Security → 2FA → App passwords)
GMAIL_USER=
GMAIL_APP_PASSWORD=
# GMAIL_BCC=
# GMAIL_REPLY_TO=
OUTREACH_SEND_DELAY_MS=150000

# Gmail API (reply detection — OAuth2, separate from app password above)
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=

# Autonomous pipeline (Mexico City time)
# PIPELINE_MAX_SEARCHES=30
# PIPELINE_TIMEZONE=America/Mexico_City

# Brevo transactional email (on standby — see lib/outreach-send-brevo.mjs)
# BREVO_API_KEY=
# OUTREACH_FROM_EMAIL=
# OUTREACH_FROM_NAME=
# OUTREACH_REPLY_TO=
# OUTREACH_BCC=

# Groq — AI outreach email drafts (console.groq.com → API Keys)
# Default: llama-3.1-8b-instant (500K tokens/day, 6K TPM)
# Best prose: llama-3.3-70b-versatile (100K tokens/day only — ~27 emails)
GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MODEL=qwen/qwen3-32b
# GROQ_TPM=6000
# GROQ_EST_TOKENS=1900
# GROQ_COOLDOWN_MS=25000
# GROQ_MAX_RETRIES=3

# GitHub Pages auto-deploy after each mockup finishes (commit + push main)
# GITHUB_DEPLOY=1
# GITHUB_REPO=https://github.com/damianbasilio/f.git
# GITHUB_TOKEN=ghp_...          # only if git push needs a token (HTTPS remote)
# GIT_REMOTE=origin
# GIT_BRANCH=main
# GIT_USER_NAME=damianbasilio
# GIT_USER_EMAIL=damian.basilio@icloud.com
# Lead discovery (Phase 1) — Google Places + DataForSEO SERP
GOOGLE_PLACES_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
# DISCOVER_MAX_GOOGLE_SEARCHES=1000
# DISCOVER_SERP_BUDGET_USD=1.00
# DISCOVER_GOOGLE_DELAY_MS=300
# DISCOVER_PLACES_PAGES=1
# DISCOVER_SERP_INITIAL_WAIT_MS=600000
# DISCOVER_SERP_READY_POLL_MS=300000
# DISCOVER_SERP_BATCH_TIMEOUT_MS=7200000
# DISCOVER_SERP_BATCH_SIZE=100
# DISCOVER_VERIFY_CONCURRENCY=2
# DISCOVER_FB_MAX_POST_AGE_MONTHS=12
# WEBSITE_CHECK_TIMEOUT_MS=8000

# Must match your GitHub account exactly. Do not use "dambasilio" or dam.basilio@gmail.com for commits.
# GITHUB_PAGES_WAIT_MS=180000
# GITHUB_PAGES_POLL_MS=10000
# POST_BUILD_MAX_RETRIES=3
# QA_AUTO_REBUILD=1
# QA_AUTO_REBUILD_MAX=2
